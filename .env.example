# GitHub personal access tokens (fine-grained or classic PATs).
#
# GH_TOKENS is the primary variable. Accepts a JSON array (preferred) or a
# comma-separated string. Supply multiple tokens to multiply your rate-limit
# allowance (5 000 req/hr per token).
#
#   JSON array format (preferred):
GH_TOKENS=["ghp_yourTokenHere"]
#
#   Comma-separated format (also accepted):
# GH_TOKENS=ghp_token1,ghp_token2
#
# Single-token fallbacks (backward-compatible, lower priority than GH_TOKENS):
# GH_TOKEN=ghp_yourTokenHere
# GITHUB_TOKEN=ghp_yourTokenHere
